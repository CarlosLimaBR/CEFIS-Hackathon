# ========================================
# Tutor IA CEFIS - Variaveis de ambiente
# ========================================
# Copie este arquivo para .env e preencha os valores.
# O arquivo .env esta no .gitignore - nunca sera commitado.

# OBRIGATORIO - Chave da OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-COLE_SUA_CHAVE_AQUI

# Modelos (defaults sao bons para hackathon)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Caminhos (defaults funcionam dentro do container)
CEFIS_DATA_DIR=./Docs/output
CEFIS_DB_PATH=./data/cefis.db

# Servidor
APP_HOST=0.0.0.0
APP_PORT=8000

# OPCIONAL - integracao com a API CEFIS (login do aluno)
# Se vazio, o tutor funciona sem login (recomendado para o hackathon)
CEFIS_API_BASE=https://cefis.com.br
CEFIS_API_V3_BASE=https://api-v3.cefis.com.br
